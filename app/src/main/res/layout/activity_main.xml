<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp"
    android:background="#E3F2FD" android:gravity="center_horizontal">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="32dp">
        <EditText android:id="@+id/etCity" android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:hint="Введите город" android:inputType="text"
            android:imeOptions="actionSearch" android:padding="12dp" android:background="@drawable/bg_input"
            android:textSize="16sp" />
        <Button android:id="@+id/btnSearch" android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Поиск" android:layout_marginStart="8dp" android:backgroundTint="#1565C0" />
    </LinearLayout>

    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginTop="24dp" android:visibility="gone" />

    <ImageView android:id="@+id/ivIcon" android:layout_width="100dp" android:layout_height="100dp"
        android:layout_marginTop="16dp" />

    <TextView android:id="@+id/tvCity" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="28sp" android:textStyle="bold" android:textColor="#0D47A1" android:layout_marginTop="8dp" />

    <TextView android:id="@+id/tvTemp" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="56sp" android:textStyle="bold" android:textColor="#1A1A1A" />

    <TextView android:id="@+id/tvDesc" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="18sp" android:textColor="#546E7A" android:layout_marginTop="4dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@android:color/white" android:elevation="4dp"
        android:padding="16dp" android:layout_marginTop="24dp">
        <TextView android:id="@+id/tvFeels" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#78909C" android:padding="4dp" />
        <TextView android:id="@+id/tvHumidity" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#78909C" android:padding="4dp" />
        <TextView android:id="@+id/tvWind" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#78909C" android:padding="4dp" />
        <TextView android:id="@+id/tvPressure" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#78909C" android:padding="4dp" />
    </LinearLayout>
</LinearLayout>
